# Notification System App - Environment Variables

# Logger Configuration
REACT_APP_LOGGER_TOKEN=your-bearer-token-here
REACT_APP_LOGGER_URL=http://20.207.122.201/evaluation-service/logs
VITE_LOGGER_TOKEN=your-bearer-token-here
VITE_LOGGER_URL=http://20.207.122.201/evaluation-service/logs

# Authentication Configuration
REACT_APP_AUTH_URL=http://20.207.122.201/evaluation-service/auth
REACT_APP_REGISTRATION_URL=http://20.207.122.201/evaluation-service/register
VITE_AUTH_URL=http://20.207.122.201/evaluation-service/auth
VITE_REGISTRATION_URL=http://20.207.122.201/evaluation-service/register

# Auth Credentials (optional)
VITE_AUTH_EMAIL=your-email@example.com
VITE_AUTH_NAME=Your Name
VITE_AUTH_ROLL_NO=yourRollNo
VITE_AUTH_ACCESS_CODE=yourAccessCode
VITE_AUTH_CLIENT_ID=yourClientId
VITE_AUTH_CLIENT_SECRET=yourClientSecret

# API Configuration
REACT_APP_API_URL=http://localhost:3000/api
VITE_API_URL=http://localhost:3000/api
VITE_API_TOKEN=your-bearer-token-here

# App Environment
REACT_APP_ENV=development
VITE_ENV=development
